# === BASE DE DATOS (Neon PostgreSQL) ===
DATABASE_URL="postgresql://USER:PASS@HOST/DB?sslmode=require"

# === NEXTAUTH ===
AUTH_SECRET="genera con: openssl rand -base64 32"
AUTH_TRUST_HOST=true

# === URLS ===
NEXT_PUBLIC_APP_URL=https://rapidoycriollo.com

# === BOT SERVICE ===
# URL interna (server-side) del bot para llamadas API
BOT_API_URL=https://bot.rapidoycriollo.com
BOT_API_SECRET="mismo valor que bot/.env BOT_API_SECRET"

# URL pública del webhook del bot (se muestra a usuarios en dashboard)
NEXT_PUBLIC_BOT_WEBHOOK_URL=https://bot.rapidoycriollo.com/webhook
