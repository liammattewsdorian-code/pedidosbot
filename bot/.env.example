# === BASE DE DATOS (Neon PostgreSQL) ===
DATABASE_URL="postgresql://USER:PASS@HOST/DB?sslmode=require"

# === SERVIDOR ===
BOT_PORT=3010
LOG_LEVEL=info
# URL pública del bot (Render te la da al crear el servicio)
BOT_PUBLIC_URL=https://rapidoycriollo-bot.onrender.com

# === SEGURIDAD ===
BOT_API_SECRET="genera con: openssl rand -hex 32"
META_WEBHOOK_VERIFY_TOKEN="token que configuras en Meta Developer Portal"

# === OPENAI (transcripción de audio) ===
OPENAI_API_KEY="sk-proj-..."

# === (opcional) Chrome para Puppeteer si aplica ===
# CHROME_PATH=/usr/bin/google-chrome
